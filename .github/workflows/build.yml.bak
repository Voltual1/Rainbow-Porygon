name: CI

on:
  workflow_dispatch:

env:
  GAME_REVISION: 0
  GAME_LANGUAGE: ENGLISH
  COMPARE: 0
  UNUSED_ERROR: 1
  DEPRECATED_ERROR: 1
  # 告诉 ccache 把缓存放在哪里，方便 Actions 收集
  CCACHE_DIR: ${{ github.workspace }}/.ccache

jobs:
  build:
    if: github.actor != 'allcontributors[bot]'
    runs-on: ubuntu-latest
    steps:
      - name: Checkout
        uses: actions/checkout@v4

      # 1. 安装依赖时顺便加上 ccache
      - name: Install binutils
        run: |
          sudo apt-get update
          sudo apt-get install -y --no-install-recommends binutils-arm-none-eabi gcc-arm-none-eabi libnewlib-arm-none-eabi libpng-dev python3 ccache

      # 2. 现有的工具缓存（保持不变）
      - name: Cache build tools
        uses: actions/cache@v4
        with:
          path: |
            tools/bin2c/bin2c
            tools/gbafix/gbafix
            tools/gbagfx/gbagfx
            tools/jsonproc/jsonproc
            tools/mapjson/mapjson
            tools/mid2agb/mid2agb
            tools/preproc/preproc
            tools/ramscrgen/ramscrgen
            tools/rsfont/rsfont
            tools/scaninc/scaninc
            tools/trainerproc/trainerproc
            tools/compresSmol/compresSmol
            tools/compresSmol/compresSmolTilemap
            tools/wav2agb/wav2agb
          key: tools-${{ runner.os }}-${{ hashFiles('tools/*/Makefile', 'tools/**/*.c', 'tools/**/*.cpp', 'tools/**/*.h') }}

      # 3. 新增：源码编译缓存 (ccache)
      - name: Cache ccache
        uses: actions/cache@v4
        with:
          path: ${{ env.CCACHE_DIR }}
          # 键名包含 commit 系统的 hash，保证每次都能更新缓存
          key: ccache-${{ runner.os }}-${{ github.sha }}
          # 如果没有精确命中，就继承上一次的缓存
          restore-keys: |
            ccache-${{ runner.os }}-

      - name: ROM (Emerald)
        env:
          GAME_VERSION: EMERALD
        run: |
          # 确保缓存目录存在
          mkdir -p ${{ env.CCACHE_DIR }}
          
          # 【核心修复 1】：允许 ccache 包装非 gcc 独立程序 (cc1)
          export CCACHE_COMPILERCHECK=none
          
          # 【核心修复 2】：非常关键！告诉 ccache 忽略由于 KEEP_TEMPS 引入的宏和临时文件绝对路径差异
          export CCACHE_SLOPPINESS=time_macros,include_file_mtime,include_file_ctime
          
          # 限制缓存大小并查看初始状态
          ccache -M 500M
          echo "=== 编译前 Ccache 状态 ==="
          ccache -s
          
          # 【核心修复 3】：获取真实的 cc1 路径
          REAL_CC1=$(arm-none-eabi-gcc --print-prog-name=cc1)
          
          # 【核心修复 4】：传入 KEEP_TEMPS=1，强迫 Makefile 落地临时文件，让 Ccache 可以抓取哈希
          make -j$(nproc) -O all CC1="ccache $REAL_CC1" KEEP_TEMPS=1
          
          # 打印编译后状态
          echo "=== 编译后 Ccache 状态 ==="
          ccache -s

      # 5. 最终状态同步
      - name: All builds passed
        run: echo "Emerald build passed."